<%= render_tabs ApplicationHelper::TRENDS_TABS, active: :links, scope: "trends.tabs" %>

<h1><%= t(".link_trends") %></h1>

<table>
  <thead>
    <tr>
      <th><%= Link.human_attribute_name(:url) %></th>
      <th><%= t(".score") %></th>
      <th><%= t(".rank") %></th>
    </tr>
  </thead>
  <tbody>
    <% @trending_links.each do |link| %>
      <tr>
        <td>
          <%= link_to truncate(link.url, length: 100), link.url %>
        </td>
        <td><%= link.score %></td>
        <td><%= link.rank %></td>
      </tr>
    <% end %>
  </tbody>
</table>
